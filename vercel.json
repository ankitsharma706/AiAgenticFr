{
  "version": 2,
  "framework": "vite",
  "rootDirectory": "frontend",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://your-node-gateway.onrender.com/api/:path*"
    },
    {
      "source": "/reports/:path*",
      "destination": "https://your-node-gateway.onrender.com/reports/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
